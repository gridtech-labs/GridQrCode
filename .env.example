# ============================================================
# QR SaaS — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# ---- App -------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---- Database --------------------------------------------------
DATABASE_URL=postgresql://qrsaas:secret@localhost:5432/qrsaas
POSTGRES_DB=qrsaas
POSTGRES_USER=qrsaas
POSTGRES_PASSWORD=secret

# ---- Redis -----------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Auth / JWT ------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_another_secret_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- AWS S3 (used from Sprint 2) --------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=qrsaas-assets

# ---- Stripe (used from Sprint 6) --------------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STARTER_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_
STRIPE_ENTERPRISE_PRICE_ID=price_

# ---- Email / SendGrid (used from Sprint 6) ----------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.
FROM_EMAIL=noreply@qrsaas.com

# ---- Super Admin -----------------------------------------------
SUPER_ADMIN_EMAIL=admin@qrsaas.com
SUPER_ADMIN_PASSWORD=change_me_strong_password
